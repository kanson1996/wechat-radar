# ── AI 模型（二选一）──

# 方式一：Anthropic Claude
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# 方式二：OpenAI 兼容接口（支持几乎所有主流模型）
# 设置 AI_PROVIDER=openai-compatible，然后填对应的 API Key、Base URL 和模型名
AI_PROVIDER=openai-compatible
AI_API_KEY=your-key-here
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
#
# 常见服务商配置参考：
#   OpenAI        — AI_BASE_URL=https://api.openai.com/v1          AI_MODEL=gpt-4o-mini
#   DeepSeek      — AI_BASE_URL=https://api.deepseek.com           AI_MODEL=deepseek-chat
#   硅基流动       — AI_BASE_URL=https://api.siliconflow.cn/v1      AI_MODEL=Qwen/Qwen2.5-72B-Instruct
#   通义千问       — AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1  AI_MODEL=qwen-plus
#   Ollama(本地)  — AI_BASE_URL=http://localhost:11434/v1          AI_MODEL=qwen2.5:7b
#   月之暗面       — AI_BASE_URL=https://api.moonshot.cn/v1         AI_MODEL=moonshot-v1-8k
#   智谱 GLM      — AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4  AI_MODEL=glm-4-flash
#   MiniMax       — AI_BASE_URL=https://api.minimax.chat/v1         AI_MODEL=abab6.5s-chat
#   百度文心       — AI_BASE_URL=https://qianfan.baidubce.com/v2     AI_MODEL=ernie-4.0-8k
#   零一万物       — AI_BASE_URL=https://api.lingyiwanwu.com/v1      AI_MODEL=yi-large
#   百川          — AI_BASE_URL=https://api.baichuan-ai.com/v1       AI_MODEL=Baichuan4
#   讯飞星火       — AI_BASE_URL=https://spark-api-open.xf-yun.com/v1  AI_MODEL=generalv3.5

# ── 推送渠道（至少配置一个，也可以都配置）──

# 飞书机器人 Webhook
# FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_HOOK_ID

# 钉钉机器人 Webhook
# DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN

# 邮件推送（支持 Gmail / QQ邮箱 / 163邮箱 / Outlook 等，自动识别 SMTP 配置）
# EMAIL_USER=your@gmail.com
# EMAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
# EMAIL_TO=recipient1@gmail.com,recipient2@qq.com
#
# 常见邮箱授权码获取方式：
#   Gmail     — https://myaccount.google.com/apppasswords（需开启两步验证）
#   QQ邮箱    — 设置 → 账户 → POP3/SMTP服务 → 开启后获取授权码
#   163邮箱   — 设置 → POP3/SMTP/IMAP → 开启后设置授权码
#   Outlook   — 直接使用账户密码（或应用密码）
#
# 如果自动识别不了你的邮箱，可以手动指定 SMTP：
# SMTP_HOST=smtp.your-domain.com
# SMTP_PORT=465

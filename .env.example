# AI Provider: "anthropic" or "openai-compatible"
AI_PROVIDER=anthropic

# Anthropic API Key (if AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI-compatible API (if AI_PROVIDER=openai-compatible)
# AI_API_KEY=your-key-here
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini

# Anthropic model to use (default: claude-haiku-4-5-20251001 for cost efficiency)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Feishu Webhook URL
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_HOOK_ID

# Gmail SMTP (Option A - simpler)
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
GMAIL_TO=recipient@gmail.com

# Gmail API (Option B - if using Google API)
# GMAIL_CREDENTIALS_FILE=~/.openclaw/workspace/scripts/wechat-digest/gmail_credentials.json

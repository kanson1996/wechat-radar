# AI Provider: "anthropic" or "openai-compatible"
AI_PROVIDER=anthropic

# Anthropic API Key (if AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI-compatible API (if AI_PROVIDER=openai-compatible)
# AI_API_KEY=your-key-here
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini

# Anthropic model to use (default: claude-haiku-4-5-20251001 for cost efficiency)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── 推送渠道（至少配置一个，也可以都配置）──

# 飞书机器人 Webhook
# FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_HOOK_ID

# 钉钉机器人 Webhook
# DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN

# 邮件推送（支持 Gmail / QQ邮箱 / 163邮箱 / Outlook 等，自动识别 SMTP 配置）
# EMAIL_USER=your@gmail.com
# EMAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
# EMAIL_TO=recipient1@gmail.com,recipient2@qq.com
#
# 常见邮箱授权码获取方式：
#   Gmail     — https://myaccount.google.com/apppasswords（需开启两步验证）
#   QQ邮箱    — 设置 → 账户 → POP3/SMTP服务 → 开启后获取授权码
#   163邮箱   — 设置 → POP3/SMTP/IMAP → 开启后设置授权码
#   Outlook   — 直接使用账户密码（或应用密码）
#
# 如果自动识别不了你的邮箱，可以手动指定 SMTP：
# SMTP_HOST=smtp.your-domain.com
# SMTP_PORT=465
